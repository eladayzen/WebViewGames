# Dependencies & build output (per-project, applies to every game folder in this repo)
node_modules/
dist/
dist-ssr/
*.local

# Zip exports/backups — redundant with already-tracked source, not meant for git
*.zip

# Raw gameplay-reference videos dropped for the pipeline's video-analyst stage —
# throwaway input material (already distilled into pipeline/reports/*.md), not
# meant for git history. Some of these run into the hundreds of MB, which
# GitHub hard-rejects outright above 100MB per file.
pipeline/videos-inbox/**/*.mp4
pipeline/videos-inbox/**/*.mov
pipeline/videos-inbox/**/*.webm
pipeline/videos-inbox/**/*.avi
pipeline/videos-inbox/**/*.mkv

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor/OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
